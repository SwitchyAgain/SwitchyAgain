{
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "noEmit": false,
    "noImplicitAny": false,
    "outDir": "build-ts",
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "target": "es2020"
  },
  "include": [
    "build.ts",
    "types/build-globals.d.ts"
  ]
}
