{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "module": "es2022",
    "moduleDetection": "force",
    "noImplicitAny": true,
    "noEmit": true,
    "paths": {
      "@switchyagain/proxy-engine": [
        "../proxy-engine/src/index.ts"
      ]
    },
    "target": "es2022",
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "test/**/*.ts",
    "types/node-globals.d.ts",
    "../proxy-engine/types/**/*.d.ts"
  ]
}
