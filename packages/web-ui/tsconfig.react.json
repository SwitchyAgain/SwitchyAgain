{
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "module": "esnext",
    "noEmit": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022"
  },
  "include": [
    "src/react/**/*.ts",
    "src/react/**/*.tsx",
    "types/**/*.d.ts"
  ]
}
