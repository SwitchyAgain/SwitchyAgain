{
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "outDir": "build-ts",
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": true,
    "target": "es2022"
  },
  "include": [
    "build.mts",
    "types/build-globals.d.ts"
  ]
}
