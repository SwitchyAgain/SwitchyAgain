{
  "name": "switchyagain-workspace",
  "private": true,
  "workspaces": [
    "omega-pac",
    "omega-target",
    "omega-web",
    "omega-target-chromium-extension"
  ],
  "scripts": {
    "build": "npm run build --workspace omega-target-chromium-extension",
    "build:pac": "npm run build --workspace omega-pac",
    "build:target": "npm run build --workspace omega-target",
    "build:web": "npm run build --workspace omega-web",
    "package:dist": "node scripts/package-dist.mjs",
    "release": "npm run release --workspace omega-target-chromium-extension",
    "test": "npm run test --workspace omega-pac && npm run test --workspace omega-target",
    "typecheck": "npm run typecheck --workspace omega-pac && npm run typecheck --workspace omega-target && npm run typecheck --workspace omega-web && npm run typecheck --workspace omega-target-chromium-extension"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.2",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.4.23",
    "buffer": "^6.0.3",
    "esbuild": "^0.28.0",
    "mocha": "^11.7.6",
    "postcss": "^8.5.6",
    "process": "^0.11.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "mocha": {
      "diff": "^8.0.3",
      "serialize-javascript": "^7.0.5"
    }
  }
}
